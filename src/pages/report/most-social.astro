---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllLogoRecords, getSocialMedia } from "../../lib/logos";
import { siteConfig } from "../../lib/site";

const socialMedia = getSocialMedia();
const rows = [];

for (const record of getAllLogoRecords()) {
  const data = record.data;
  if (!data.logohandle) continue;

  const count = socialMedia.reduce((sum, sm) => sum + (data[sm.id] ? 1 : 0), 0);
  if (count >= 8) {
    rows.push({ data, count });
  }
}
---
<BaseLayout pageTitle={`Most Social - ${siteConfig.title}`} noindex={true}>
  <p>Logos with the most social media links in their metadata</p>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Logo</th>
        <th># social media links</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <td><a href={`/logos/${row.data.logohandle}/index.html`}>{row.data.title}</a></td>
          <td>{row.count}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <p>Maximum possible score: {socialMedia.length}</p>
</BaseLayout>
