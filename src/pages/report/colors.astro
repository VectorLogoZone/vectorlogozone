---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllLogoRecords } from "../../lib/logos";
import { siteConfig } from "../../lib/site";

const records = ((await getAllLogoRecords())).filter((record) => record.data.logohandle);
const logocount = records.length;
const withColors = records.filter((record) => Array.isArray(record.data.colors) && record.data.colors.length > 0);
const colorcount = withColors.length;
---
<BaseLayout pageTitle={`Logo Color Report - ${siteConfig.title}`}>
  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Logo</th>
        <th>Colors</th>
        <th>Images</th>
      </tr>
    </thead>
    <tbody>
      {
        withColors.map((record) => {
          const data = record.data;
          const ar21file = `${data.logohandle}-ar21.svg`;
          const iconfile = `${data.logohandle}-icon.svg`;
          const tilefile = `${data.logohandle}-tile.svg`;
          return (
            <tr>
              <td><a href={`/logos/${data.logohandle}/index.html`}>{data.title}</a></td>
              <td>
                {data.colors.map((color) => (
                  <Fragment>
                    <div class="preview-color" style={`background-color:${color}`}></div> {color} &nbsp;
                  </Fragment>
                ))}
              </td>
              <td>
                {data.images.includes(iconfile) && <a href={`/util/preview.html?image=/logos/${data.logohandle}/${iconfile}&next=/report/colors.html`} rel="nofollow"><img src={`/logos/${data.logohandle}/${iconfile}`} style="height:30px;" /></a>}
                {data.images.includes(tilefile) && <a href={`/util/preview.html?image=/logos/${data.logohandle}/${tilefile}&next=/report/colors.html`} rel="nofollow"><img src={`/logos/${data.logohandle}/${tilefile}`} style="height:30px;" /></a>}
                {data.images.includes(ar21file) && <a href={`/util/preview.html?image=/logos/${data.logohandle}/${ar21file}&next=/report/colors.html`} rel="nofollow"><img src={`/logos/${data.logohandle}/${ar21file}`} style="height:30px;" /></a>}
              </td>
            </tr>
          );
        })
      }
      <tr>
        <td>&nbsp;</td>
        <td class="text-center">{colorcount.toLocaleString("en-US")} {logocount > 0 ? `(${Math.floor((colorcount * 100) / logocount)}%)` : ""}</td>
        <td>&nbsp;</td>
      </tr>
    </tbody>
  </table>
</BaseLayout>
