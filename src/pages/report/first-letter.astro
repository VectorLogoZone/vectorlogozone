---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllLogoRecords } from "../../lib/logos";
import { siteConfig } from "../../lib/site";

const records = ((await getAllLogoRecords())).filter((record) => record.data.logohandle);
const letterStats = [];
let currentLetter = "";
let done = 0;
let pending = 0;

for (const record of records) {
  const letter = (record.data.sort || "").slice(0, 1).toUpperCase() || "#";
  if (letter !== currentLetter) {
    if (currentLetter) {
      letterStats.push({ letter: currentLetter, done, pending, total: done + pending });
    }
    currentLetter = letter;
    done = 0;
    pending = 0;
  }

  if (Array.isArray(record.data.images) && record.data.images.length > 0) {
    done += 1;
  } else {
    pending += 1;
  }
}

if (currentLetter) {
  letterStats.push({ letter: currentLetter, done, pending, total: done + pending });
}
---
<BaseLayout pageTitle={`Count by First Letter - ${siteConfig.title}`} noindex={true}>
  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Letter</th>
        <th>Done</th>
        <th>Pending</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      {letterStats.map((row) => (
        <tr>
          <td><a href={`/index.html?q=${encodeURIComponent(row.letter)}`}>{row.letter}</a></td>
          <td>{row.done.toLocaleString("en-US")}</td>
          <td>{row.pending.toLocaleString("en-US")}</td>
          <td>{row.total.toLocaleString("en-US")}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <p>{letterStats.length.toLocaleString("en-US")} different starting letters</p>
</BaseLayout>
