---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllLogoRecords, getSocialMedia } from "../../lib/logos";
import { siteConfig } from "../../lib/site";

const socialMedia = getSocialMedia();
const rows = [];

for (const record of (await getAllLogoRecords())) {
  const data = record.data;
  if (!data.logohandle) continue;

  const count = socialMedia.reduce((sum, sm) => sum + (data[sm.id] ? 1 : 0), 0);
  if (count === 0) {
    rows.push(data);
  }
}
---
<BaseLayout pageTitle={`Least Social - ${siteConfig.title}`} noindex={true}>
  <p>Logos with no social media links in their metadata</p>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Logo</th>
        <th>Search</th>
        <th></th>
      </tr>
    </thead>
    <tbody>
      {rows.map((data) => (
        <tr>
          <td><a href={`/logos/${data.logohandle}/index.html`}>{data.title}</a></td>
          <td>
            <a href={`https://www.google.com/search?q=${encodeURIComponent(data.title)}`} rel="nofollow">Google</a>
            | <a href={`https://twitter.com/search?q=${encodeURIComponent(data.title)}&src=typd`} rel="nofollow">Twitter</a>
            {data.website && <Fragment> | <a href={data.website}>Website</a></Fragment>}
          </td>
          <td><a href={`https://github.com/VectorLogoZone/vectorlogozone/blob/main/src/content/logos/${encodeURIComponent(data.logohandle)}/index.md`} rel="nofollow">edit</a></td>
        </tr>
      ))}
    </tbody>
  </table>

  <p>{rows.length} logos with no social links</p>
</BaseLayout>
