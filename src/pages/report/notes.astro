---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllLogoRecords } from "../../lib/logos";
import { siteConfig } from "../../lib/site";

const rows = ((await getAllLogoRecords())).filter((record) => record.data.logohandle && record.data.notes);
---
<BaseLayout pageTitle={`Notes`} noindex={true}>
  <p>Normally notes should get processed and removed before publishing, but sometimes they are missed.</p>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>ID</th>
        <th>Name</th>
        <th>Notes</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((record) => (
        <tr>
          <td><a href={`/logos/${record.data.logohandle}/index.html`}>[{record.data.logohandle}]</a></td>
          <td>{record.data.title}</td>
          <td>{record.data.notes}</td>
        </tr>
      ))}
      {rows.length === 0 && (
        <tr>
          <td colspan="3"><i>(none)</i></td>
        </tr>
      )}
    </tbody>
  </table>

  <p># of logos with notes: {rows.length}</p>
</BaseLayout>
