---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getImageTypes, getVisibleLogoRecords } from "../../lib/logos";
import { siteConfig } from "../../lib/site";

const imageTypes = getImageTypes().filter((type) => type.inventory);
const records = (await getVisibleLogoRecords());
const checkOn = '<i class="fa fa-check"></i>';
const checkOff = '<i class="fa fa-fw"></i>';

const totalsByType = Object.fromEntries(imageTypes.map((type) => [type.id, 0]));
let totalImages = 0;
let totalDisplayedCells = 0;

for (const record of records) {
  const images = record.data.images || [];
  totalImages += images.length;

  let count = images.length;
  for (const type of imageTypes) {
    const file = `${record.data.logohandle}-${type.id}.svg`;
    if (images.includes(file)) {
      totalsByType[type.id] += 1;
      count -= 1;
      totalDisplayedCells += 1;
    }
  }

  if (count > 0) {
    totalDisplayedCells += count;
  }
}
---
<BaseLayout pageTitle={`Logo Inventory`} noindex={true}>
  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Name</th>
        {imageTypes.map((type) => <th class="d-none d-lg-table-cell d-print-table-cell">{type.title}</th>)}
        <th class="d-none d-lg-table-cell d-print-table-cell">Other</th>
        <th>Total</th>
      </tr>
    </thead>
    <tbody>
      {records.map((record) => {
        const data = record.data;
        let count = data.images.length;
        return (
          <tr>
            <td><a href={`/logos/${data.logohandle}/index.html`}>{data.title || "(untitled)"}</a></td>
            {
              imageTypes.map((type) => {
                const file = `${data.logohandle}-${type.id}.svg`;
                const has = data.images.includes(file);
                if (has) count -= 1;
                return <td class="text-center d-none d-lg-table-cell d-print-table-cell" set:html={has ? checkOn : checkOff}></td>;
              })
            }
            <td class="text-center d-none d-lg-table-cell d-print-table-cell">{count > 0 ? count : ""}</td>
            <td class="text-center">{data.images.length}</td>
          </tr>
        );
      })}
    </tbody>
    <tfoot>
      <tr>
        <td class="text-right">Total:</td>
        {imageTypes.map((type) => <td class="text-center d-none d-lg-table-cell d-print-table-cell">{totalsByType[type.id].toLocaleString("en-US")}</td>)}
        <td class="text-center d-none d-lg-table-cell d-print-table-cell">&nbsp;</td>
        <td class="text-center">{totalImages.toLocaleString("en-US")}</td>
      </tr>
    </tfoot>
  </table>

  <p>{totalDisplayedCells.toLocaleString("en-US")} images for {records.length.toLocaleString("en-US")} companies/projects.</p>
</BaseLayout>
