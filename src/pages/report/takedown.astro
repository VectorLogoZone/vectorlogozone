---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllLogoRecords } from "../../lib/logos";
import { siteConfig } from "../../lib/site";

const rows = ((await getAllLogoRecords())).filter((record) => record.data.logohandle && record.data.noindex);
---
<BaseLayout pageTitle={`Takedown Requests - ${siteConfig.title}`} noindex={true}>
  <p>The following logos have been removed at their owners' request.</p>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th class="text-center d-none d-lg-table-cell d-print-table-cell">ID</th>
        <th>Name</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((record) => (
        <tr>
          <td class="text-center d-none d-lg-table-cell d-print-table-cell"><a href={`/logos/${record.data.logohandle}/index.html`}>{record.data.logohandle}</a></td>
          <td>{record.data.website ? <a href={record.data.website}>{record.data.title || "(untitled)"}</a> : (record.data.title || "(untitled)")}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <p>{rows.length.toLocaleString("en-US")} logos with something missing</p>
</BaseLayout>
