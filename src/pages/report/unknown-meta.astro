---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { getAllLogoRecords, getSocialMedia } from "../../lib/logos";
import { siteConfig } from "../../lib/site";

const stdMeta = new Set([
  "colors",
  "font",
  "guide",
  "images",
  "keywords",
  "logohandle",
  "noindex",
  "notes",
  "posted",
  "redirect_from",
  "sort",
  "tags",
  "title",
  "website",
  "wikipedia"
]);

const todoMeta = [
  "angellist",
  "behance",
  "discord",
  "discourse",
  "dockerhub",
  "dribbble",
  "flickr",
  "flipboard",
  "gitter",
  "glassdoor",
  "keypass",
  "mastodon",
  "medium",
  "meetup",
  "opencollective",
  "other",
  "slack",
  "slideshare",
  "snapchat",
  "soundcloud",
  "stackexchange",
  "stackoverflow",
  "vimeo",
  "vine",
  "weibo",
  "xing"
];

for (const id of todoMeta) stdMeta.add(id);
for (const sm of getSocialMedia()) stdMeta.add(sm.id);

const rows = [];
for (const record of getAllLogoRecords()) {
  const data = record.data;
  if (!data.logohandle) continue;

  const unknown = Object.keys(data).filter((key) => !stdMeta.has(key));
  if (unknown.length > 0) {
    rows.push({ data, unknown });
  }
}
---
<BaseLayout pageTitle={`Unknown metadata - ${siteConfig.title}`} noindex={true}>
  <p>Logos with unknown entries in their metadata</p>

  <table class="table table-striped table-bordered">
    <thead>
      <tr>
        <th>Logo</th>
        <th>Unknown entries</th>
      </tr>
    </thead>
    <tbody>
      {rows.map((row) => (
        <tr>
          <td><a href={`/logos/${row.data.logohandle}/index.html`}>{row.data.title}</a></td>
          <td>{row.unknown.length}: {row.unknown.join(",")}</td>
        </tr>
      ))}
    </tbody>
  </table>

  <p># of logos with unknown metadata: {rows.length}</p>
</BaseLayout>
