---
import BaseLayout from "../../layouts/BaseLayout.astro";
import { siteConfig } from "../../lib/site";
---
<BaseLayout pageTitle={`Links`}>
  <style>
    .pin-title { font-size: 1em; text-decoration: none; color: #00a; }
    .pin-description { color: #555; }
    .pin-tag { display: none; }
  </style>

  <div class="row">
    <div class="panel-body">
      <script src="https://pinboard.in/widgets/v1/linkroll/?user=fileformat&amp;count=400&amp;tag=vectorlogozone"></script>
    </div>
  </div>
</BaseLayout>
