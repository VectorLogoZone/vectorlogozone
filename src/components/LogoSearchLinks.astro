---
import { siteConfig } from "../lib/site";

const { title } = Astro.props;
const query = encodeURIComponent(title);
---
<p>
  Find alternatives:
  <a href={`https://logosear.ch/search.html?q=${query}`} title="Search on Logo Search"><img alt="Logo Search logo" class="searchlogo" src="https://logosear.ch/favicon.svg" /></a>
  <a href={`https://commons.wikimedia.org/w/index.php?search=${query}+filemime%3Asvg`} title="Search on Wikimedia Commons"><img alt="Wikipedia logo" class="searchlogo" src={`${siteConfig.productionUrl}/logos/wikipedia/wikipedia-tile.svg`} /></a>
  <a href={`https://www.google.com/search?tbm=isch&tbs=ift:svg&q=${query}`} rel="nofollow" title="Search with Google Image Search"><img alt="Google logo" class="searchlogo" src={`${siteConfig.productionUrl}/logos/google/google-tile.svg`} /></a>
</p>
